# MongoDB connection string (required)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/nexushub

# JWT secret – use a long random string
JWT_SECRET=your_super_secret_jwt_key_here

# Your UPI ID shown to buyers
UPI_ID=8799390922@fam

# Gmail for sending emails — use App Password, NOT your real Gmail password
# Step 1: Go to https://myaccount.google.com/security
# Step 2: Enable 2-Step Verification first
# Step 3: Go to https://myaccount.google.com/apppasswords
# Step 4: Select "Mail" → Generate → copy the 16-char code
EMAIL_USER=pkirtan546@gmail.com
EMAIL_PASS=your_16_char_app_password_here

# Admin email (receives alerts)
ADMIN_EMAIL=pkirtan546@gmail.com

# Your Vercel deployment URL (set this after deploying)
SITE_URL=https://your-app.vercel.app
ADMIN_URL=https://your-app.vercel.app/admin.html
