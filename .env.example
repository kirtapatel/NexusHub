# MongoDB connection string (required)
# Get a free cluster at https://mongodb.com/atlas
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/nexushub

# JWT secret – use a long random string
JWT_SECRET=your_super_secret_jwt_key_here

# Your UPI ID shown to buyers in the payment modal
UPI_ID=yourname@upi

# Email (Gmail) for sending notifications
# Use a Gmail App Password: https://myaccount.google.com/apppasswords
EMAIL_USER=youremail@gmail.com
EMAIL_PASS=your_gmail_app_password

# Admin email (receives payment alerts)
ADMIN_EMAIL=admin@yourdomain.com

# Your site URL (used in email links)
SITE_URL=https://your-app.vercel.app

# Admin panel URL (used in admin alert emails)
ADMIN_URL=https://your-app.vercel.app/admin.html
